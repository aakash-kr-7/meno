# ==============================================================================
# (a) What this file is: Environment Configuration template file.
# (b) What it does: Defines default config variables for the MENO system services.
# (c) How it fits into the MENO system: Used to initialize local environments (.env) with valid secrets and host configuration.
# ==============================================================================

DATABASE_URL=postgresql+asyncpg://meno:meno@localhost:5432/meno
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change_me_in_production
API_KEY_HEADER=X-API-Key
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
SESSION_TTL_SECONDS=86400
PROMOTION_THRESHOLD=20
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
LLM_EXTRACTION_ENABLED=false
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-6
MENO_MCP_TRANSPORT=stdio
MENO_MCP_HOST=0.0.0.0
MENO_MCP_PORT=8765
